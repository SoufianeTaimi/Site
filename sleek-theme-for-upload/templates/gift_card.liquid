{% layout 'none' %}

<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex,nofollow">
  <title>{{ 'gift_cards.redeem.title' | t }}</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="gift-card-page">
  <main class="gift-card" role="main">
    <div class="gift-card__wrapper">
      {% if gift_card.enabled %}
        <div class="gift-card__header">
          <h1 class="gift-card__heading">{{ 'gift_cards.redeem.title' | t }}</h1>
          {% if gift_card.customer %}
            <p class="gift-card__from">{{ 'gift_cards.redeem.from' | t: name: gift_card.customer.name }}</p>
          {% endif %}
        </div>

        <div class="gift-card__amount-wrapper">
          <div class="gift-card__amount">
            <span class="gift-card__price">{{ gift_card.balance | money }}</span>
          </div>
          <p class="gift-card__code">{{ gift_card.code | format_code }}</p>
          <p class="gift-card__expires">
            {% if gift_card.expires_on %}
              {{ 'gift_cards.redeem.expires' | t: date: gift_card.expires_on | date: '%B %d, %Y' }}
            {% endif %}
          </p>
        </div>

        <div class="gift-card__actions">
          <a href="{{ shop.url }}" class="button button--primary">
            {{ 'gift_cards.redeem.shop_link' | t }}
          </a>
          <button onclick="window.print();" class="button button--secondary">
            {{ 'gift_cards.redeem.print' | t }}
          </button>
        </div>

        <div class="gift-card__qr">
          <img src="{{ gift_card.qr_image }}" alt="{{ 'gift_cards.redeem.qr_alt' | t }}" loading="lazy" width="120" height="120">
        </div>
      {% else %}
        <div class="gift-card__disabled">
          <h2>{{ 'gift_cards.redeem.disabled' | t }}</h2>
        </div>
      {% endif %}
    </div>
  </main>
</body>
</html>
