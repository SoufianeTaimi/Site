{
  "sections": {
    "article-header": {
      "type": "rich-text",
      "settings": {
        "heading": "{{ article.title }}",
        "text": "<p>{{ article.author }} &middot; {{ article.published_at | date: '%B %d, %Y' }}</p>",
        "alignment": "center"
      }
    },
    "article-content": {
      "type": "image-with-text",
      "settings": {
        "heading": "{{ article.title }}",
        "text": "{{ article.content }}"
      }
    },
    "article-recommended": {
      "type": "featured-collection",
      "settings": {
        "title": "You might also like"
      }
    }
  },
  "order": ["article-header", "article-content", "article-recommended"]
}
