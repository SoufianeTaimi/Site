{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign button_text = section.settings.button_text
  assign button_link = section.settings.button_link
  assign button_style = section.settings.button_style | default: 'primary'
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign content_width = section.settings.content_width | default: 'medium'
  assign color_scheme = section.settings.color_scheme | default: 'light'
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign show_divider = section.settings.show_divider
  assign divider_position = section.settings.divider_position | default: 'bottom'
  assign heading_size = section.settings.heading_size | default: 'h2'
-%}
{%- assign heading_tag = heading_size -%}
<section
  class="rich-text rich-text--{{ color_scheme }}"
  data-section-id="{{ section_id }}"
  style="
    --padding-top: {{ padding_top }}px;
    --padding-bottom: {{ padding_bottom }}px;
  "
>
  <div class="rich-text__container rich-text__container--{{ content_width }}">
    {%- if show_divider and divider_position == 'top' -%}
      <hr class="rich-text__divider" aria-hidden="true">
    {%- endif -%}
    <div class="rich-text__content rich-text__content--{{ text_alignment }}">
      {%- if heading != blank -%}
        <{{ heading_tag }} class="rich-text__heading rich-text__heading--{{ heading_size }}">
          {{ heading }}
        </{{ heading_tag }}>
      {%- endif -%}
      {%- if description != blank -%}
        <div class="rich-text__description">{{ description }}</div>
      {%- endif -%}
      {%- if button_text != blank and button_link != blank -%}
        <div class="rich-text__btn-wrapper">
          <a href="{{ button_link }}" class="rich-text__btn btn btn--{{ button_style }}">
            {{ button_text }}
            <span class="btn__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      {%- endif -%}
    </div>
    {%- if show_divider and divider_position == 'bottom' -%}
      <hr class="rich-text__divider" aria-hidden="true">
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "shopify-section-rich-text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Clean Beauty"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our philosophy is rooted in simplicity and sustainability. We believe that what you put on your body should be as pure as what you put in it. Discover the difference that clean ingredients and thoughtful formulation can make.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "outline", "label": "Outline" },
        { "value": "text", "label": "Text" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Maximum content width",
      "options": [
        { "value": "narrow", "label": "Narrow (600px)" },
        { "value": "medium", "label": "Medium (800px)" },
        { "value": "wide", "label": "Wide (1000px)" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show decorative divider",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_position",
      "label": "Divider position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (white/beige)" },
        { "value": "dark", "label": "Dark (black/charcoal)" },
        { "value": "accent", "label": "Accent (warm beige)" }
      ],
      "default": "light"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "settings": {
        "heading": "The Art of Clean Beauty",
        "heading_size": "h2",
        "description": "<p>Our philosophy is rooted in simplicity and sustainability. We believe that what you put on your body should be as pure as what you put in it. Discover the difference that clean ingredients and thoughtful formulation can make.</p>",
        "button_text": "Read Our Story",
        "button_style": "primary",
        "text_alignment": "center",
        "content_width": "medium",
        "show_divider": false,
        "divider_position": "bottom",
        "color_scheme": "light",
        "padding_top": 64,
        "padding_bottom": 64
      }
    }
  ]
}
{% endschema %}
