{%- liquid
  assign logo_image = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign sticky_enabled = section.settings.enable_sticky
  assign menu = section.settings.menu
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign header_id = 'shopify-section-header-' | append: section.id
  assign cart_count = cart.item_count
-%}
{%- capture logo_html -%}
  <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
    {%- if logo_image != blank -%}
      {%- assign logo_alt = logo_image.alt | default: shop.name -%}
      {{
        logo_image
        | image_url: width: logo_width
        | image_tag:
          class: 'header__logo',
          alt: logo_alt,
          widths: '180, 360, 540',
          style: 'max-width: ' | append: logo_width | append: 'px;'
      }}
    {%- else -%}
      <span class="header__logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>
{%- endcapture -%}
<{% if sticky_enabled %}sticky-header{% else %}div{% endif %}
  class="shopify-section-header header-section"
  data-section-id="{{ section.id }}"
  data-sticky="{{ sticky_enabled }}"
  style="--header-bg: {{ bg_color }}; --header-text: {{ text_color }};"
>
  <header id="{{ header_id }}" class="header" role="banner">
    <div class="header__container">
      {# ---- Mobile hamburger ---- #}
      <button
        class="header__hamburger"
        type="button"
        aria-label="{{ 'sections.header.menu_toggle' | t }}"
        aria-expanded="false"
        data-drawer-trigger
      >
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
      </button>
      {# ---- Logo ---- #}
      <div class="header__logo-wrapper">
        {{ logo_html }}
      </div>
      {# ---- Navigation center ---- #}
      <nav class="header__nav" role="navigation" aria-label="{{ 'sections.header.main_nav' | t }}">
        <ul class="header__nav-list">
          {%- if menu != blank -%}
            {%- for link in linklists[menu].links -%}
              {%- assign has_dropdown = false -%}
              {%- if link.links != blank -%}
                {%- assign has_dropdown = true -%}
              {%- endif -%}
              <li class="header__nav-item{% if has_dropdown %} header__nav-item--has-dropdown{% endif %}{% if link.active %} header__nav-item--active{% endif %}">
                <a
                  href="{{ link.url }}"
                  class="header__nav-link"
                  {% if has_dropdown %}aria-haspopup="true" aria-expanded="false"{% endif %}
                >
                  {{ link.title }}
                  {%- if has_dropdown -%}
                    <span class="header__nav-arrow" aria-hidden="true">
                      <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  {%- endif -%}
                </a>
                {%- if has_dropdown -%}
                  <div class="header__dropdown mega-menu">
                    <div class="mega-menu__inner">
                      <ul class="mega-menu__grid">
                        {%- for sub_link in link.links -%}
                          <li class="mega-menu__column">
                            <a href="{{ sub_link.url }}" class="mega-menu__heading">{{ sub_link.title }}</a>
                            {%- if sub_link.links != blank -%}
                              <ul class="mega-menu__sublist">
                                {%- for sub_sub_link in sub_link.links -%}
                                  <li>
                                    <a href="{{ sub_sub_link.url }}" class="mega-menu__sublink">{{ sub_sub_link.title }}</a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </nav>
      {# ---- Icon group ---- #}
      <div class="header__actions">
        <button
          class="header__action-btn header__search-toggle"
          type="button"
          aria-label="{{ 'sections.header.search' | t }}"
          data-search-toggle
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14L18.5 18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <a
          href="{{ routes.account_url }}"
          class="header__action-btn header__account-link"
          aria-label="{{ 'sections.header.account' | t }}"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 18C3 14.6863 6.13401 12 10 12C13.866 12 17 14.6863 17 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <a
          href="{{ routes.cart_url }}"
          class="header__action-btn header__cart-link"
          aria-label="{{ 'sections.header.cart' | t }}"
          data-cart-toggle
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M5 7H15L16.5 17H3.5L5 7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 7V5C7 3.34315 8.34315 2 10 2C11.6569 2 13 3.34315 13 5V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          {%- if cart_count > 0 -%}
            <span class="header__cart-count" aria-hidden="true">{{ cart_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>
    {# ---- Mobile drawer ---- #}
    <div class="header__drawer" role="dialog" aria-modal="true" aria-label="{{ 'sections.header.menu' | t }}">
      <div class="header__drawer-overlay" data-drawer-close></div>
      <div class="header__drawer-inner">
        <button class="header__drawer-close" type="button" data-drawer-close aria-label="{{ 'sections.header.close_menu' | t }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <nav class="header__drawer-nav">
          <ul class="header__drawer-list">
            {%- if menu != blank -%}
              {%- for link in linklists[menu].links -%}
                <li class="header__drawer-item{% if link.links != blank %} header__drawer-item--has-children{% endif %}">
                  <a href="{{ link.url }}" class="header__drawer-link">{{ link.title }}</a>
                  {%- if link.links != blank -%}
                    <button class="header__drawer-toggle" type="button" aria-expanded="false" data-drawer-sub-toggle>
                      <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                    <ul class="header__drawer-sublist">
                      {%- for sub_link in link.links -%}
                        <li>
                          <a href="{{ sub_link.url }}" class="header__drawer-sublink">{{ sub_link.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </nav>
      </div>
    </div>
  </header>
</{% if sticky_enabled %}sticky-header{% else %}div{% endif %}>
{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "shopify-section-header-group",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Upload your brand logo. SVG or PNG recommended."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 80,
      "max": 280,
      "step": 10,
      "default": 180,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Header background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Header text color",
      "default": "#1A1A1A"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_banner",
      "name": "Mega menu banner",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        },
        {
          "type": "text",
          "id": "banner_heading",
          "label": "Banner heading",
          "default": "New Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "settings": {
        "menu": "main-menu",
        "logo_width": 180,
        "enable_sticky": true,
        "bg_color": "#FFFFFF",
        "text_color": "#1A1A1A"
      }
    }
  ]
}
{% endschema %}
