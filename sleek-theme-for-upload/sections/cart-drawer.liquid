{%- liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign free_shipping_threshold = section.settings.free_shipping_threshold | default: 0
  assign cart_total = cart.total_price
  assign free_shipping_remaining = free_shipping_threshold | minus: cart_total
  assign free_shipping_progress = 0
  if free_shipping_threshold > 0
    assign free_shipping_progress = cart_total | times: 100.0 | divided_by: free_shipping_threshold
    if free_shipping_progress > 100
      assign free_shipping_progress = 100
    endif
  endif
-%}
<cart-drawer
  class="cart-drawer"
  data-section-id="{{ section.id }}"
  style="--drawer-bg: {{ bg_color }}; --drawer-text: {{ text_color }}; --drawer-accent: {{ accent_color }};"
>
  {# ---- Backdrop overlay ---- #}
  <div class="cart-drawer__overlay" data-cart-overlay></div>
  <div class="cart-drawer__inner" role="dialog" aria-modal="true" aria-label="{{ 'sections.cart_drawer.title' | t }}">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">{{ 'sections.cart_drawer.title' | t }}</h2>
      <button
        class="cart-drawer__close"
        type="button"
        aria-label="{{ 'sections.cart_drawer.close' | t }}"
        data-cart-close
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    {%- if free_shipping_threshold > 0 and free_shipping_progress < 100 -%}
      <div class="cart-drawer__shipping-bar">
        <div class="cart-drawer__shipping-text">
          {%- if free_shipping_remaining > 0 -%}
            {{ 'sections.cart_drawer.shipping_remaining' | t: amount: free_shipping_remaining | money }}
          {%- else -%}
            {{ 'sections.cart_drawer.shipping_free' | t }}
          {%- endif -%}
        </div>
        <div class="cart-drawer__progress-track">
          <div
            class="cart-drawer__progress-fill"
            style="width: {{ free_shipping_progress }}%;"
            role="progressbar"
            aria-valuenow="{{ free_shipping_progress }}"
            aria-valuemin="0"
            aria-valuemax="100"
          ></div>
        </div>
      </div>
    {%- endif -%}
    <div class="cart-drawer__items" data-cart-items>
      {%- if cart.item_count == 0 -%}
        <div class="cart-drawer__empty">
          <div class="cart-drawer__empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 2L3 6V20C3 20.5304 3.21071 21.0391 3.58579 21.4142C3.96086 21.7893 4.46957 22 5 22H19C19.5304 22 20.0391 21.7893 20.4142 21.4142C20.7893 21.0391 21 20.5304 21 20V6L18 2H6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 10C16 11.0609 15.5786 12.0783 14.8284 12.8284C14.0783 13.5786 13.0609 14 12 14C10.9391 14 9.92172 13.5786 9.17157 12.8284C8.42143 12.0783 8 11.0609 8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="cart-drawer__empty-text">{{ 'sections.cart_drawer.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__continue-btn btn btn--primary">
            {{ 'sections.cart_drawer.continue_shopping' | t }}
          </a>
        </div>
      {%- else -%}
        <ul class="cart-drawer__items-list">
          {%- for item in cart.items -%}
            <li class="cart-drawer__item" data-cart-item data-key="{{ item.key }}">
              <div class="cart-drawer__item-image">
                {%- if item.image -%}
                  {{
                    item.image
                    | image_url: width: 120
                    | image_tag:
                      class: 'cart-drawer__item-img',
                      alt: item.title,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  <div class="cart-drawer__item-placeholder">{{ 'product' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {%- endif -%}
              </div>
              <div class="cart-drawer__item-details">
                <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                {%- if item.variant.title != 'Default Title' -%}
                  <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
                {%- endif -%}
                <div class="cart-drawer__item-bottom">
                  <div class="cart-drawer__item-quantity">
                    <button
                      class="cart-drawer__qty-btn cart-drawer__qty-minus"
                      type="button"
                      aria-label="{{ 'sections.cart_drawer.decrease_qty' | t }}"
                      data-qty-minus
                    >
                      <svg width="12" height="2" viewBox="0 0 12 2" fill="none"><path d="M1 1H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </button>
                    <input
                      class="cart-drawer__qty-input"
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="{{ 'sections.cart_drawer.quantity' | t }}"
                      data-qty-input
                    >
                    <button
                      class="cart-drawer__qty-btn cart-drawer__qty-plus"
                      type="button"
                      aria-label="{{ 'sections.cart_drawer.increase_qty' | t }}"
                      data-qty-plus
                    >
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6H11M6 1V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </button>
                  </div>
                  <div class="cart-drawer__item-prices">
                    {%- if item.original_price != item.final_price -%}
                      <span class="cart-drawer__item-compare-price">{{ item.original_price | money }}</span>
                    {%- endif -%}
                    <span class="cart-drawer__item-price">{{ item.final_price | money }}</span>
                  </div>
                </div>
                <button
                  class="cart-drawer__item-remove"
                  type="button"
                  aria-label="{{ 'sections.cart_drawer.remove' | t }}"
                  data-cart-remove
                >
                  {{ 'sections.cart_drawer.remove' | t }}
                </button>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span>{{ 'sections.cart_drawer.subtotal' | t }}</span>
          <span class="cart-drawer__subtotal-amount">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__tax-note">{{ 'sections.cart_drawer.tax_and_shipping' | t }}</p>
        <form action="{{ routes.cart_url }}" method="post" novalidate>
          <button type="submit" name="checkout" class="cart-drawer__checkout-btn btn btn--primary btn--full">
            {{ 'sections.cart_drawer.checkout' | t }} &mdash; {{ cart.total_price | money }}
          </button>
        </form>
      </div>
    {%- endif -%}
  </div>
</cart-drawer>
{% schema %}
{
  "name": "Cart drawer",
  "tag": "section",
  "class": "shopify-section-cart-drawer",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Drawer background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / button color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Free shipping"
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold ($)",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 50,
      "unit": "$"
    }
  ],
  "presets": [
    {
      "name": "Cart drawer",
      "settings": {
        "bg_color": "#FFFFFF",
        "text_color": "#1A1A1A",
        "accent_color": "#1A1A1A",
        "free_shipping_threshold": 50
      }
    }
  ]
}
{% endschema %}
