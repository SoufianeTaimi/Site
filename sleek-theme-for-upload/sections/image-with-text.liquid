{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign button_text = section.settings.button_text
  assign button_link = section.settings.button_link
  assign button_style = section.settings.button_style | default: 'primary'
  assign image = section.settings.image
  assign mobile_image = section.settings.mobile_image | default: image
  assign image_width = section.settings.image_width | default: '50'
  assign layout = section.settings.layout
  assign desktop_content_position = section.settings.desktop_content_position
  assign mobile_content_position = section.settings.mobile_content_position
  assign color_scheme = section.settings.color_scheme
  assign section_height = section.settings.section_height
-%}
{%- assign content_width = 100 | minus: image_width -%}
<section
  class="image-with-text image-with-text--{{ layout }} image-with-text--{{ color_scheme }}"
  data-section-id="{{ section_id }}"
  style="
    --image-width: {{ image_width }}%;
    --content-width: {{ content_width }}%;
    --section-height: {{ section_height }};
    --desktop-content-position: {{ desktop_content_position }};
    --mobile-content-position: {{ mobile_content_position }};
  "
>
  <div class="image-with-text__container">
    <div class="image-with-text__grid">
      <!-- Image Column -->
      <div class="image-with-text__image-wrapper">
        {%- if image != blank -%}
          <div class="image-with-text__image-inner">
            {{
              image
              | image_url: width: 1200
              | image_tag:
                class: 'image-with-text__image image-with-text__image--desktop',
                alt: image.alt | default: heading,
                loading: 'lazy',
                widths: '400, 600, 800, 1000, 1200'
            }}
            {%- if mobile_image != image and mobile_image != blank -%}
              {{
                mobile_image
                | image_url: width: 800
                | image_tag:
                  class: 'image-with-text__image image-with-text__image--mobile',
                  alt: mobile_image.alt | default: heading,
                  loading: 'lazy',
                  widths: '400, 600, 800'
              }}
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="image-with-text__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
      <!-- Content Column -->
      <div class="image-with-text__content-wrapper">
        <div class="image-with-text__content">
          {%- if heading != blank -%}
            <h2 class="image-with-text__heading">{{ heading }}</h2>
          {%- endif -%}
          {%- if text != blank -%}
            <div class="image-with-text__text">{{ text }}</div>
          {%- endif -%}
          {%- if button_text != blank and button_link != blank -%}
            <a href="{{ button_link }}" class="image-with-text__btn btn btn--{{ button_style }}">
              {{ button_text }}
              <span class="btn__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "class": "shopify-section-image-with-text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 1200px wide, high quality."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image (optional)",
      "info": "If blank, the desktop image is used on mobile."
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width (%)",
      "min": 30,
      "max": 70,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "auto", "label": "Auto (match content)" },
        { "value": "60vh", "label": "Short (60vh)" },
        { "value": "75vh", "label": "Medium (75vh)" },
        { "value": "100vh", "label": "Full screen (100vh)" }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        { "value": "image-left", "label": "Image left, text right" },
        { "value": "image-right", "label": "Image right, text left" }
      ],
      "default": "image-left"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Desktop content vertical alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_content_position",
      "label": "Mobile content position",
      "info": "On mobile the image stacks above the text.",
      "options": [
        { "value": "before", "label": "Content after image" },
        { "value": "after", "label": "Content before image" }
      ],
      "default": "before"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clean Beauty, Naturally"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Describe your product philosophy, brand story, or a key selling point. Use this space to connect with your customers emotionally through compelling copy.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "outline", "label": "Outline" },
        { "value": "text", "label": "Text" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light (white/beige)" },
        { "value": "dark", "label": "Dark (black/charcoal)" },
        { "value": "accent", "label": "Accent (warm beige)" }
      ],
      "default": "light"
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "settings": {
        "image": "",
        "image_width": 50,
        "section_height": "auto",
        "layout": "image-left",
        "desktop_content_position": "center",
        "mobile_content_position": "before",
        "heading": "Clean Beauty, Naturally",
        "text": "<p>Describe your product philosophy, brand story, or a key selling point. Use this space to connect with your customers emotionally through compelling copy.</p>",
        "button_text": "Learn More",
        "button_link": "",
        "button_style": "primary",
        "color_scheme": "light"
      }
    }
  ]
}
{% endschema %}
