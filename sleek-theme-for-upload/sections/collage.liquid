{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign layout_mode = section.settings.layout_mode | default: 'masonry'
  assign desktop_height = section.settings.desktop_height | default: '400px'
  assign mobile_height = section.settings.mobile_height | default: '250px'
  assign show_overlay = section.settings.show_overlay
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign hover_effect = section.settings.hover_effect | default: 'zoom'
  assign block_count = section.blocks.size
  assign columns = section.settings.columns | default: 3
-%}
<section
  class="collage collage--{{ layout_mode }} collage--hover-{{ hover_effect }}"
  data-section-id="{{ section_id }}"
  style="
    --desktop-height: {{ desktop_height }};
    --mobile-height: {{ mobile_height }};
    --overlay-opacity: {{ overlay_opacity }};
    --collage-columns: {{ columns }};
  "
>
  <div class="collage__container">
    {%- if heading != blank or subheading != blank -%}
      <div class="collage__heading-wrapper">
        {%- if subheading != blank -%}
          <p class="collage__subheading">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="collage__heading">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if block_count > 0 -%}
      <div class="collage__grid" data-collage-grid>
        {%- for block in section.blocks -%}
          {%- liquid
            assign image = block.settings.image
            assign mobile_image = block.settings.mobile_image | default: image
            assign heading_text = block.settings.heading
            assign subtext = block.settings.subtext
            assign link = block.settings.link
            assign image_width_desktop = block.settings.image_width_desktop | default: '1'
            assign image_width_mobile = block.settings.image_width_mobile | default: '1'
            assign image_height_desktop = block.settings.image_height_desktop | default: '1'
            assign height_span = block.settings.height_span | default: 'standard'
            assign width_span = block.settings.width_span | default: 'standard'
            assign overlay_text_color = block.settings.overlay_text_color | default: '#FFFFFF'
          -%}
          {%- case height_span -%}
            {%- when 'tall' -%}
              {%- assign row_span = 'span-2' -%}
            {%- else -%}
              {%- assign row_span = 'span-1' -%}
          {%- endcase -%}
          {%- case width_span -%}
            {%- when 'wide' -%}
              {%- assign col_span = 'span-2' -%}
            {%- when 'full' -%}
              {%- assign col_span = 'span-full' -%}
            {%- else -%}
              {%- assign col_span = 'span-1' -%}
          {%- endcase -%}
          <div
            class="collage__item collage__item--{{ row_span }} collage__item--{{ col_span }}"
            style="--overlay-text-color: {{ overlay_text_color }};"
            {{ block.shopify_attributes }}
          >
            {%- if link != blank -%}
              <a href="{{ link }}" class="collage__item-link" aria-label="{{ heading_text | default: 'Image' }}">
            {%- endif -%}
            <div class="collage__item-image-wrapper">
              {%- if image != blank -%}
                {{
                  image
                  | image_url: width: 1200
                  | image_tag:
                    class: 'collage__item-image collage__item-image--desktop',
                    alt: image.alt | default: heading_text,
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200'
                }}
                {%- if mobile_image != image and mobile_image != blank -%}
                  {{
                    mobile_image
                    | image_url: width: 800
                    | image_tag:
                      class: 'collage__item-image collage__item-image--mobile',
                      alt: mobile_image.alt | default: heading_text,
                      loading: 'lazy',
                      widths: '400, 600, 800'
                  }}
                {%- endif -%}
              {%- else -%}
                <div class="collage__item-placeholder">
                  {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
              {%- if show_overlay -%}
                <div class="collage__item-overlay"></div>
              {%- endif -%}
            </div>
            {%- if heading_text != blank or subtext != blank -%}
              <div class="collage__item-content">
                {%- if heading_text != blank -%}
                  <h3 class="collage__item-heading">{{ heading_text }}</h3>
                {%- endif -%}
                {%- if subtext != blank -%}
                  <div class="collage__item-subtext">{{ subtext }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="collage__grid" data-collage-grid>
        {%- for i in (1..5) -%}
          <div class="collage__item collage__item--span-1 collage__item--span-1">
            <div class="collage__item-image-wrapper">
              <div class="collage__item-placeholder">
                {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Collage",
  "tag": "section",
  "class": "shopify-section-collage",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our World"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A visual journey through the brand"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "options": [
        { "value": "masonry", "label": "Masonry (natural flow)" },
        { "value": "grid", "label": "Uniform grid" }
      ],
      "default": "masonry"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Number of columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "desktop_height",
      "label": "Desktop item height",
      "info": "CSS value (e.g., 400px, 50vh). Standard items only.",
      "default": "400px"
    },
    {
      "type": "text",
      "id": "mobile_height",
      "label": "Mobile item height",
      "info": "CSS value for standard items on mobile.",
      "default": "250px"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay on hover",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover effect",
      "options": [
        { "value": "zoom", "label": "Zoom in" },
        { "value": "fade", "label": "Fade overlay" },
        { "value": "slide", "label": "Slide up content" },
        { "value": "none", "label": "No effect" }
      ],
      "default": "zoom"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 1200px wide, high quality."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (optional)",
          "info": "If blank, desktop image is used."
        },
        {
          "type": "header",
          "content": "Size & span"
        },
        {
          "type": "select",
          "id": "width_span",
          "label": "Width span",
          "options": [
            { "value": "standard", "label": "Standard (1 column)" },
            { "value": "wide", "label": "Wide (2 columns)" },
            { "value": "full", "label": "Full width" }
          ],
          "default": "standard"
        },
        {
          "type": "select",
          "id": "height_span",
          "label": "Height span",
          "options": [
            { "value": "standard", "label": "Standard" },
            { "value": "tall", "label": "Tall (2 rows)" }
          ],
          "default": "standard"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Brand Story"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Discover our journey"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "overlay_text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collage",
      "settings": {
        "heading": "Our World",
        "subheading": "A visual journey through the brand",
        "layout_mode": "masonry",
        "columns": 3,
        "desktop_height": "400px",
        "mobile_height": "250px",
        "show_overlay": true,
        "overlay_opacity": 30,
        "hover_effect": "zoom"
      },
      "blocks": [
        {
          "type": "image",
          "settings": {
            "image": "",
            "width_span": "wide",
            "height_span": "standard",
            "heading": "Our Story",
            "subtext": "Where it all began"
          }
        },
        {
          "type": "image",
          "settings": {
            "image": "",
            "width_span": "standard",
            "height_span": "tall",
            "heading": "Sustainability",
            "subtext": "Our commitment"
          }
        },
        {
          "type": "image",
          "settings": {
            "image": "",
            "width_span": "standard",
            "height_span": "standard",
            "heading": "Ingredients",
            "subtext": "What goes in"
          }
        },
        {
          "type": "image",
          "settings": {
            "image": "",
            "width_span": "standard",
            "height_span": "standard",
            "heading": "The Ritual",
            "subtext": "Daily essentials"
          }
        },
        {
          "type": "image",
          "settings": {
            "image": "",
            "width_span": "wide",
            "height_span": "standard",
            "heading": "Community",
            "subtext": "Join the movement"
          }
        }
      ]
    }
  ]
}
{% endschema %}
