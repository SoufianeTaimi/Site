{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign desktop_columns = section.settings.desktop_columns | default: 4
  assign mobile_columns = section.settings.mobile_columns | default: 2
  assign layout_style = section.settings.layout_style | default: 'features'
  assign block_count = section.blocks.size
  assign icon_shape = section.settings.icon_shape | default: 'none'
-%}
<section class="multi-column multi-column--{{ layout_style }}" data-section-id="{{ section_id }}">
  <div class="multi-column__container">
    {%- if heading != blank or subheading != blank -%}
      <div class="multi-column__heading-wrapper">
        {%- if subheading != blank -%}
          <p class="multi-column__subheading">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="multi-column__heading">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div
      class="multi-column__grid"
      style="
        --desktop-columns: {{ desktop_columns }};
        --mobile-columns: {{ mobile_columns }};
        --icon-shape: {{ icon_shape }};
      "
    >
      {%- if block_count > 0 -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign block_heading = block.settings.heading
            assign block_text = block.settings.text
            assign icon_type = block.settings.icon_type
            assign icon_custom = block.settings.icon_custom
            assign icon_svg = block.settings.icon_svg
            assign link = block.settings.link
          -%}
          <div class="multi-column__column" {{ block.shopify_attributes }}>
            {%- if icon_type == 'image' and icon_custom != blank -%}
              <div class="multi-column__icon multi-column__icon--image">
                {{
                  icon_custom
                  | image_url: width: 100
                  | image_tag:
                    class: 'multi-column__icon-img',
                    alt: block_heading,
                    loading: 'lazy',
                    widths: '50, 100'
                }}
              </div>
            {%- elsif icon_type == 'svg' and icon_svg != blank -%}
              <div class="multi-column__icon multi-column__icon--svg" aria-hidden="true">
                {{ icon_svg }}
              </div>
            {%- elsif icon_type == 'emoji' and block.settings.emoji_icon != blank -%}
              <div class="multi-column__icon multi-column__icon--emoji" aria-hidden="true">
                <span class="multi-column__emoji">{{ block.settings.emoji_icon }}</span>
              </div>
            {%- else -%}
              <div class="multi-column__icon multi-column__icon--placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
                </svg>
              </div>
            {%- endif -%}
            <div class="multi-column__content">
              {%- if block_heading != blank -%}
                <h3 class="multi-column__column-heading">
                  {%- if link != blank -%}
                    <a href="{{ link }}" class="multi-column__column-link">{{ block_heading }}</a>
                  {%- else -%}
                    {{ block_heading }}
                  {%- endif -%}
                </h3>
              {%- endif -%}
              {%- if block_text != blank -%}
                <div class="multi-column__column-text">{{ block_text }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign placeholder_count = desktop_columns | plus: 0 -%}
        {%- for i in (1..placeholder_count) -%}
          <div class="multi-column__column multi-column__column--placeholder">
            <div class="multi-column__icon multi-column__icon--placeholder">
              {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="multi-column__content">
              <h3 class="multi-column__column-heading">{{ 'sections.multi_column.placeholder_heading' | t }}</h3>
              <div class="multi-column__column-text">{{ 'sections.multi_column.placeholder_text' | t }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Multi-column",
  "tag": "section",
  "class": "shopify-section-multi-column",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Sleek difference"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "features", "label": "Features (icon on top)" },
        { "value": "press", "label": "Press mentions (logo on top)" },
        { "value": "centered", "label": "Centered text" }
      ],
      "default": "features"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "Icon shape",
      "options": [
        { "value": "none", "label": "None (natural shape)" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" },
        { "value": "rounded", "label": "Rounded square" }
      ],
      "default": "none"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "header",
          "content": "Icon"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "emoji", "label": "Emoji" },
            { "value": "none", "label": "No icon" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "icon_custom",
          "label": "Custom icon image",
          "info": "Recommended: 100x100px PNG or SVG."
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG code",
          "info": "Paste inline SVG markup."
        },
        {
          "type": "text",
          "id": "emoji_icon",
          "label": "Emoji icon",
          "default": "🌿"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Brief description of this feature or value proposition.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi-column",
      "settings": {
        "heading": "Why Choose Us",
        "subheading": "The Sleek difference",
        "layout_style": "features",
        "desktop_columns": "4",
        "mobile_columns": "2",
        "icon_shape": "circle"
      },
      "blocks": [
        {
          "type": "column",
          "settings": {
            "icon_type": "emoji",
            "emoji_icon": "🚚",
            "heading": "Free Shipping",
            "text": "<p>Free standard shipping on all orders over $50.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon_type": "emoji",
            "emoji_icon": "💎",
            "heading": "Money Guarantee",
            "text": "<p>30-day money-back guarantee. No questions asked.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon_type": "emoji",
            "emoji_icon": "💳",
            "heading": "Flexible Payment",
            "text": "<p>Pay in installments with Klarna, Afterpay, and more.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "icon_type": "emoji",
            "emoji_icon": "💬",
            "heading": "Online Support",
            "text": "<p>Chat with our team 7 days a week.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
