{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign show_arrows = section.settings.show_arrows
  assign show_dots = section.settings.show_dots
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | default: 5
  assign star_color = section.settings.star_color | default: '#D4AF37'
  assign slide_count = section.blocks.size
-%}
<section class="testimonials" data-section-id="{{ section_id }}">
  <div class="testimonials__container">
    {%- if heading != blank or subheading != blank -%}
      <div class="testimonials__heading-wrapper">
        {%- if subheading != blank -%}
          <p class="testimonials__subheading">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="testimonials__heading">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if slide_count > 0 -%}
      <div
        class="testimonials__slider"
        data-testimonials-slider
        data-autoplay="{{ autoplay }}"
        data-autoplay-speed="{{ autoplay_speed | times: 1000 }}"
        data-slide-count="{{ slide_count }}"
        style="--star-color: {{ star_color }};"
        role="region"
        aria-label="{{ 'sections.testimonials.aria_label' | t }}"
        aria-roledescription="carousel"
      >
        <div class="testimonials__track" data-slider-track>
          {%- for block in section.blocks -%}
            {%- liquid
              assign quote = block.settings.quote
              assign rating = block.settings.rating | default: 5
              assign author_name = block.settings.author_name
              assign author_location = block.settings.author_location
              assign verified_badge = block.settings.verified_badge
              assign product_image = block.settings.product_image
              assign product_url = block.settings.product_url
              assign author_avatar = block.settings.author_avatar
            -%}
            <div
              class="testimonials__slide"
              data-index="{{ forloop.index0 }}"
              role="group"
              aria-roledescription="slide"
              aria-label="{{ 'sections.testimonials.slide' | t: slide_number: forloop.index, total_slides: slide_count }}"
              {{ block.shopify_attributes }}
            >
              <div class="testimonials__card">
                <div class="testimonials__card-content">
                  <!-- Star Rating -->
                  <div class="testimonials__stars" aria-label="{{ 'sections.testimonials.rating' | t: rating: rating }}">
                    {%- for i in (1..5) -%}
                      {%- if i <= rating -%}
                        <svg class="testimonials__star testimonials__star--filled" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      {%- else -%}
                        <svg class="testimonials__star testimonials__star--empty" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <!-- Quote -->
                  {%- if quote != blank -%}
                    <blockquote class="testimonials__quote">
                      <p>{{ quote }}</p>
                    </blockquote>
                  {%- endif -%}
                  <!-- Author -->
                  <div class="testimonials__author">
                    {%- if author_avatar != blank -%}
                      <div class="testimonials__author-avatar">
                        {{
                          author_avatar
                          | image_url: width: 100
                          | image_tag:
                            class: 'testimonials__author-avatar-img',
                            alt: author_name,
                            loading: 'lazy',
                            widths: '50, 100'
                        }}
                      </div>
                    {%- endif -%}
                    <div class="testimonials__author-info">
                      <cite class="testimonials__author-name">{{ author_name }}</cite>
                      {%- if author_location != blank -%}
                        <span class="testimonials__author-location">{{ author_location }}</span>
                      {%- endif -%}
                      {%- if verified_badge -%}
                        <span class="testimonials__verified-badge">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                          </svg>
                          {{ 'sections.testimonials.verified_buyer' | t }}
                        </span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
                <!-- Product Image Linked -->
                {%- if product_image != blank -%}
                  <div class="testimonials__product">
                    {%- if product_url != blank -%}
                      <a href="{{ product_url }}" class="testimonials__product-link" aria-label="{{ 'sections.testimonials.view_product' | t }}">
                    {%- endif -%}
                    {{
                      product_image
                      | image_url: width: 200
                      | image_tag:
                        class: 'testimonials__product-image',
                        alt: 'Product',
                        loading: 'lazy',
                        widths: '100, 200'
                    }}
                    {%- if product_url != blank -%}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
        <!-- Navigation Arrows -->
        {%- if show_arrows and slide_count > 1 -%}
          <button
            class="testimonials__arrow testimonials__arrow--prev"
            type="button"
            aria-label="{{ 'sections.testimonials.previous' | t }}"
            data-slider-prev
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M15 19L8 12L15 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button
            class="testimonials__arrow testimonials__arrow--next"
            type="button"
            aria-label="{{ 'sections.testimonials.next' | t }}"
            data-slider-next
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
        <!-- Dots -->
        {%- if show_dots and slide_count > 1 -%}
          <div class="testimonials__dots" role="tablist" aria-label="{{ 'sections.testimonials.slide_selector' | t }}">
            {%- for block in section.blocks -%}
              <button
                class="testimonials__dot{% if forloop.first %} testimonials__dot--active{% endif %}"
                type="button"
                role="tab"
                aria-label="{{ 'sections.testimonials.go_to_slide' | t: slide_number: forloop.index }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-slide-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="testimonials__placeholder">
        <p>{{ 'sections.testimonials.no_testimonials' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "shopify-section-testimonials",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real customers"
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star rating color",
      "default": "#D4AF37"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "header",
          "content": "Review content"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Customer quote",
          "default": "Absolutely love this product! The quality is outstanding and the packaging is beautiful. Will definitely be ordering again."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "header",
          "content": "Author"
        },
        {
          "type": "image_picker",
          "id": "author_avatar",
          "label": "Author avatar"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah J."
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author location",
          "default": "New York, NY"
        },
        {
          "type": "checkbox",
          "id": "verified_badge",
          "label": "Show 'Verified Buyer' badge",
          "default": true
        },
        {
          "type": "header",
          "content": "Product"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
        "heading": "What Our Customers Say",
        "subheading": "Real reviews from real customers",
        "show_arrows": true,
        "show_dots": true,
        "autoplay": true,
        "autoplay_speed": 5,
        "star_color": "#D4AF37"
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Absolutely love this product! The quality is outstanding and the packaging is beautiful. Will definitely be ordering again.",
            "rating": 5,
            "author_name": "Sarah J.",
            "author_location": "New York, NY",
            "verified_badge": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The texture is incredible. My skin has never felt this smooth. A must-have for anyone with sensitive skin.",
            "rating": 5,
            "author_name": "Emma L.",
            "author_location": "Los Angeles, CA",
            "verified_badge": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Beautifully formulated and smells divine. Every product I've tried from this brand has exceeded expectations.",
            "rating": 4,
            "author_name": "Michael R.",
            "author_location": "Chicago, IL",
            "verified_badge": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
