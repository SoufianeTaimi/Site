{%- liquid
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | default: 5
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height
  assign show_arrows = section.settings.show_arrows
  assign show_dots = section.settings.show_dots
  assign slideshow_id = 'slideshow-' | append: section.id
  assign slide_count = section.blocks.size
-%}
{%- if slide_count > 0 -%}
<div
  id="{{ slideshow_id }}"
  class="slideshow"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-speed="{{ autoplay_speed | times: 1000 }}"
  data-slide-count="{{ slide_count }}"
  style="--slideshow-desktop-height: {{ desktop_height }}; --slideshow-mobile-height: {{ mobile_height }};"
  role="region"
  aria-label="{{ 'sections.slideshow.aria_label' | t }}"
  aria-roledescription="carousel"
>
  <div class="slideshow__track" data-slideshow-track>
    {%- for block in section.blocks -%}
      {%- liquid
        assign image = block.settings.image
        assign eyebrow = block.settings.eyebrow
        assign heading = block.settings.heading
        assign description = block.settings.description
        assign button_text = block.settings.button_text
        assign button_link = block.settings.button_link
        assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
        assign text_align = block.settings.text_align
        assign text_color = block.settings.text_color
        assign mobile_image = block.settings.mobile_image | default: image
      -%}
      <div
        class="slideshow__slide"
        data-index="{{ forloop.index0 }}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ 'sections.slideshow.slide' | t: slide_number: forloop.index, total_slides: slide_count }}"
        {{ block.shopify_attributes }}
      >
        {%- if image != blank -%}
          <div class="slideshow__image-wrapper">
            {{
              image
              | image_url: width: 2000
              | image_tag:
                class: 'slideshow__image slideshow__image--desktop',
                alt: image.alt | default: heading,
                loading: 'lazy',
                widths: '600, 900, 1200, 1600, 2000'
            }}
            {%- if mobile_image != image and mobile_image != blank -%}
              {{
                mobile_image
                | image_url: width: 800
                | image_tag:
                  class: 'slideshow__image slideshow__image--mobile',
                  alt: mobile_image.alt | default: heading,
                  loading: 'lazy',
                  widths: '400, 600, 800'
              }}
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="slideshow__placeholder">
            {{ 'hero' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <div
          class="slideshow__overlay"
          style="background: rgba(0,0,0,{{ overlay_opacity }});"
        ></div>
        <div class="slideshow__content slideshow__content--{{ text_align }}">
          <div class="slideshow__content-inner" style="color: {{ text_color }};">
            {%- if eyebrow != blank -%}
              <p class="slideshow__eyebrow">{{ eyebrow }}</p>
            {%- endif -%}
            {%- if heading != blank -%}
              <h2 class="slideshow__heading">{{ heading }}</h2>
            {%- endif -%}
            {%- if description != blank -%}
              <div class="slideshow__description">{{ description }}</div>
            {%- endif -%}
            {%- if button_text != blank and button_link != blank -%}
              <a href="{{ button_link }}" class="slideshow__btn btn">
                {{ button_text }}
                <span class="btn__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
  {%- if show_arrows and slide_count > 1 -%}
    <button class="slideshow__arrow slideshow__arrow--prev" type="button" aria-label="{{ 'sections.slideshow.previous' | t }}" data-slideshow-prev>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 19L8 12L15 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="slideshow__arrow slideshow__arrow--next" type="button" aria-label="{{ 'sections.slideshow.next' | t }}" data-slideshow-next>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {%- endif -%}
  {%- if show_dots and slide_count > 1 -%}
    <div class="slideshow__dots" role="tablist" aria-label="{{ 'sections.slideshow.slide_selector' | t }}">
      {%- for block in section.blocks -%}
        <button
          class="slideshow__dot{% if forloop.first %} slideshow__dot--active{% endif %}"
          type="button"
          role="tab"
          aria-label="{{ 'sections.slideshow.go_to_slide' | t: slide_number: forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
{%- endif -%}
{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "shopify-section-slideshow",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop height",
      "options": [
        { "value": "60vh", "label": "Short (60vh)" },
        { "value": "75vh", "label": "Medium (75vh)" },
        { "value": "90vh", "label": "Tall (90vh)" },
        { "value": "100vh", "label": "Full screen (100vh)" }
      ],
      "default": "75vh"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        { "value": "40vh", "label": "Short (40vh)" },
        { "value": "50vh", "label": "Medium (50vh)" },
        { "value": "60vh", "label": "Tall (60vh)" },
        { "value": "auto", "label": "Auto (natural height)" }
      ],
      "default": "50vh"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image",
          "info": "Recommended: 2000px wide, high quality."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (optional)",
          "info": "If blank, desktop image is used."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity (%)",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 20
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "New Arrivals"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Clean Beauty, Elevated"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Discover our curated collection of luxury essentials."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "settings": {
        "desktop_height": "75vh",
        "mobile_height": "50vh",
        "show_arrows": true,
        "show_dots": true,
        "autoplay": true,
        "autoplay_speed": 5
      },
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "image": "",
            "text_color": "#FFFFFF",
            "text_align": "center",
            "overlay_opacity": 20,
            "eyebrow": "New Arrivals",
            "heading": "Clean Beauty, Elevated",
            "description": "Discover our curated collection of luxury essentials.",
            "button_text": "Shop Now",
            "button_link": ""
          }
        },
        {
          "type": "slide",
          "settings": {
            "image": "",
            "text_color": "#FFFFFF",
            "text_align": "center",
            "overlay_opacity": 20,
            "eyebrow": "Limited Edition",
            "heading": "The Ritual Collection",
            "description": "Handcrafted for the modern minimalist.",
            "button_text": "Explore",
            "button_link": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
