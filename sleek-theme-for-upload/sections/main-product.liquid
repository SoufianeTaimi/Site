{%- liquid
  assign product = product
  assign selected_variant = product.selected_or_first_available_variant
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media
  assign media_count = product.media.size
  assign section_id = section.id
  assign enable_image_zoom = section.settings.enable_image_zoom
  assign enable_video_looping = section.settings.enable_video_looping
  assign sticky_add_to_cart = section.settings.sticky_add_to_cart
  assign show_share_buttons = section.settings.show_share_buttons
  assign show_pickup_availability = section.settings.show_pickup_availability
  assign show_stock_counter = section.settings.show_stock_counter
  assign stock_counter_threshold = section.settings.stock_counter_threshold | default: 20
-%}
{%- assign product_form_id = 'product-form-' | append: section_id -%}
<section class="main-product" data-section-id="{{ section_id }}" data-product-handle="{{ product.handle }}">
  <div class="main-product__container">
    <!-- Breadcrumbs -->
    <nav class="main-product__breadcrumbs" aria-label="Breadcrumbs">
      <ol class="main-product__breadcrumbs-list">
        <li class="main-product__breadcrumbs-item">
          <a href="{{ routes.root_url }}" class="main-product__breadcrumbs-link">{{ 'general.breadcrumbs.home' | t }}</a>
        </li>
        {%- if collection -%}
          <li class="main-product__breadcrumbs-item">
            <a href="{{ collection.url }}" class="main-product__breadcrumbs-link">{{ collection.title }}</a>
          </li>
        {%- endif -%}
        <li class="main-product__breadcrumbs-item main-product__breadcrumbs-item--current">
          <span aria-current="page">{{ product.title }}</span>
        </li>
      </ol>
    </nav>
    <div class="main-product__grid">
      <!-- Gallery -->
      <div class="main-product__gallery">
        <div class="main-product__gallery-main" data-gallery-main>
          {%- for media in product.media -%}
            <div
              class="main-product__media-item{% if media.id == featured_media.id %} main-product__media-item--active{% endif %}"
              data-media-id="{{ media.id }}"
              data-media-type="{{ media.media_type }}"
            >
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  <div class="main-product__image-wrapper"{% if enable_image_zoom %} data-image-zoom{% endif %}>
                    {{
                      media
                      | image_url: width: 1200
                      | image_tag:
                        class: 'main-product__image',
                        alt: media.alt | default: product.title,
                        loading: 'lazy',
                        widths: '400, 600, 800, 1000, 1200'
                    }}
                  </div>
                {%- when 'video' -%}
                  <div class="main-product__video-wrapper">
                    {{
                      media
                      | media_tag:
                        class: 'main-product__video',
                        image_size: '800x',
                        autoplay: true,
                        loop: enable_video_looping,
                        controls: true,
                        preload: 'metadata'
                    }}
                  </div>
                {%- when 'external_video' -%}
                  <div class="main-product__external-video-wrapper">
                    {{
                      media
                      | external_video_tag:
                        class: 'main-product__external-video',
                        loading: 'lazy'
                    }}
                  </div>
                {%- when 'model' -%}
                  <div class="main-product__model-wrapper">
                    {{
                      media
                      | model_viewer_tag:
                        class: 'main-product__model',
                        image_size: '800x',
                        reveal: 'interaction',
                        toggleable: true,
                        data-model-id: media.id
                    }}
                  </div>
              {%- endcase -%}
            </div>
          {%- else -%}
            <div class="main-product__image-placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endfor -%}
        </div>
        {%- if media_count > 1 -%}
          <div class="main-product__thumbnails" data-thumbnails>
            {%- for media in product.media -%}
              <button
                class="main-product__thumbnail{% if media.id == featured_media.id %} main-product__thumbnail--active{% endif %}"
                type="button"
                aria-label="{{ 'sections.main_product.thumbnail_label' | t: index: forloop.index }}"
                data-thumbnail-id="{{ media.id }}"
              >
                {{
                  media
                  | image_url: width: 200
                  | image_tag:
                    class: 'main-product__thumbnail-image',
                    alt: media.alt | default: product.title,
                    loading: 'lazy',
                    widths: '100, 200'
                }}
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  <span class="main-product__thumbnail-badge" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <!-- Product Info -->
      <div class="main-product__info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'badge' -%}
              <div class="main-product__badge-wrapper" {{ block.shopify_attributes }}>
                {%- if product.available == false -%}
                  <span class="main-product__badge main-product__badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
                {%- elsif product.compare_at_price > product.price -%}
                  <span class="main-product__badge main-product__badge--sale">{{ 'products.product.on_sale' | t }}</span>
                {%- endif -%}
                {%- if product.tags contains 'new' -%}
                  <span class="main-product__badge main-product__badge--new">{{ 'products.product.new' | t }}</span>
                {%- endif -%}
              </div>
            {%- when 'vendor' -%}
              <p class="main-product__vendor" {{ block.shopify_attributes }}>
                {{ product.vendor | link_to_vendor }}
              </p>
            {%- when 'title' -%}
              <h1 class="main-product__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>
            {%- when 'price' -%}
              <div class="main-product__pricing" {{ block.shopify_attributes }}>
                <div class="main-product__price-wrapper">
                  <span class="main-product__price" data-product-price>
                    {{ current_variant.price | money }}
                  </span>
                  {%- if current_variant.compare_at_price > current_variant.price -%}
                    <span class="main-product__compare-at-price" data-compare-price>
                      {{ current_variant.compare_at_price | money }}
                    </span>
                    <span class="main-product__savings">
                      {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
                      {{ 'products.product.save' | t: amount: savings | money }}
                    </span>
                  {%- endif -%}
                </div>
                {%- if product.taxes_shown -%}
                  {%- if product.tax_included -%}
                    <span class="main-product__tax-notice">{{ 'products.product.include_taxes' | t }}</span>
                  {%- endif -%}
                {%- endif -%}
                {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                  <span class="main-product__shipping-notice">{{ 'products.product.shipping_policy_html' | t }}</span>
                {%- endif -%}
              </div>
            {%- when 'reviews' -%}
              <div class="main-product__reviews" {{ block.shopify_attributes }}>
                <div class="main-product__reviews-stars" data-reviews-stars>
                  <!-- Review app integration placeholder -->
                  <span class="main-product__reviews-link" data-reviews-scroll>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    <span>{{ 'sections.main_product.reviews_link' | t }}</span>
                  </span>
                </div>
              </div>
            {%- when 'description' -%}
              <div class="main-product__description" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>
            {%- when 'stock_counter' -%}
              {%- if show_stock_counter and product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                {%- liquid
                  assign inventory_quantity = product.selected_or_first_available_variant.inventory_quantity
                  assign threshold = stock_counter_threshold | plus: 0
                -%}
                {%- if inventory_quantity <= threshold and inventory_quantity > 0 -%}
                  <div class="main-product__stock-counter" {{ block.shopify_attributes }}>
                    <div class="main-product__stock-bar">
                      <div class="main-product__stock-bar-fill" style="width: {{ inventory_quantity | divided_by: threshold | times: 100 }}%;"></div>
                    </div>
                    <p class="main-product__stock-text">
                      {{ 'sections.main_product.stock_count_html' | t: count: inventory_quantity }}
                    </p>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- when 'variant_picker' -%}
              <div class="main-product__variant-picker" {{ block.shopify_attributes }}>
                {%- unless product.has_only_default_variant -%}
                  {%- for option in product.options_with_values -%}
                    {%- liquid
                      assign option_name = option.name | downcase
                      assign is_color = false
                      if option_name contains 'color' or option_name contains 'colour' or option_name contains 'couleur'
                        assign is_color = true
                      endif
                    -%}
                    <div class="main-product__option-selector" data-option-selector>
                      <label class="main-product__option-label" for="option-{{ section_id }}-{{ forloop.index0 }}">
                        {{ option.name }}: <span class="main-product__option-selected">{{ option.selected_value }}</span>
                      </label>
                      <div class="main-product__option-values" role="radiogroup" aria-label="{{ option.name }}">
                        {%- for value in option.values -%}
                          {%- if is_color -%}
                            <label class="main-product__color-swatch{% if value == option.selected_value %} main-product__color-swatch--active{% endif %}">
                              <input
                                type="radio"
                                class="main-product__color-swatch-input"
                                name="{{ option.name | handleize }}"
                                value="{{ value | escape }}"
                                {% if value == option.selected_value %}checked{% endif %}
                                data-option-value
                              >
                              <span
                                class="main-product__color-swatch-visual"
                                style="background-color: {{ value | split: ' ' | last | downcase }};"
                                title="{{ value | escape }}"
                              ></span>
                              <span class="visually-hidden">{{ value }}</span>
                            </label>
                          {%- else -%}
                            <label class="main-product__option-btn{% if value == option.selected_value %} main-product__option-btn--active{% endif %}">
                              <input
                                type="radio"
                                class="main-product__option-btn-input"
                                name="{{ option.name | handleize }}"
                                value="{{ value | escape }}"
                                {% if value == option.selected_value %}checked{% endif %}
                                data-option-value
                              >
                              <span class="main-product__option-btn-label">{{ value }}</span>
                            </label>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                {%- endunless -%}
              </div>
            {%- when 'quantity' -%}
              <div class="main-product__quantity" {{ block.shopify_attributes }}>
                <label class="main-product__quantity-label" for="quantity-{{ section_id }}">
                  {{ 'products.product.quantity' | t }}
                </label>
                <div class="main-product__quantity-selector">
                  <button
                    class="main-product__quantity-btn main-product__quantity-btn--minus"
                    type="button"
                    aria-label="{{ 'products.product.decrease_quantity' | t }}"
                    data-quantity-minus
                  >
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                  <input
                    class="main-product__quantity-input"
                    id="quantity-{{ section_id }}"
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    aria-label="{{ 'products.product.quantity' | t }}"
                    data-quantity-input
                  >
                  <button
                    class="main-product__quantity-btn main-product__quantity-btn--plus"
                    type="button"
                    aria-label="{{ 'products.product.increase_quantity' | t }}"
                    data-quantity-plus
                  >
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
              </div>
            {%- when 'buy_buttons' -%}
              <div class="main-product__buy-buttons" {{ block.shopify_attributes }}>
                {%- form 'product', product, id: product_form_id, class: 'main-product__form' -%}
                  <input type="hidden" name="id" value="{{ current_variant.id }}">
                  <button
                    class="main-product__add-to-cart btn btn--primary"
                    type="submit"
                    name="add"
                    {% unless current_variant.available %}disabled{% endunless %}
                    data-add-to-cart
                  >
                    <span data-add-to-cart-text>
                      {%- if current_variant.available -%}
                        {{ 'products.product.add_to_cart' | t }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- endif -%}
                    </span>
                    <span class="main-product__add-to-cart-price" data-add-to-cart-price>
                      {{ current_variant.price | money }}
                    </span>
                  </button>
                  {%- if block.settings.show_dynamic_checkout -%}
                    <div class="main-product__dynamic-checkout">
                      {{ form | payment_button }}
                    </div>
                  {%- endif -%}
                {%- endform -%}
              </div>
            {%- when 'pickup_availability' -%}
              {%- if show_pickup_availability -%}
                <div class="main-product__pickup" {{ block.shopify_attributes }}>
                  {%- render 'pickup-availability',
                    product: product,
                    variant: current_variant,
                    section_id: section_id
                  -%}
                </div>
              {%- endif -%}
            {%- when 'shipping_info' -%}
              <div class="main-product__shipping-info" {{ block.shopify_attributes }}>
                <div class="main-product__shipping-info-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{{ 'sections.main_product.free_shipping' | t }}</span>
                </div>
                <div class="main-product__shipping-info-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{{ 'sections.main_product.secure_checkout' | t }}</span>
                </div>
                <div class="main-product__shipping-info-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                  <span>{{ 'sections.main_product.easy_returns' | t }}</span>
                </div>
              </div>
            {%- when 'collapsible_tabs' -%}
              <div class="main-product__collapsible-tabs" {{ block.shopify_attributes }}>
                {%- assign tab_titles = block.settings.tab_titles | newline_to_br | strip_newlines | split: '<br />' -%}
                {%- assign tab_contents = block.settings.tab_contents | split: '---' -%}
                <div class="main-product__tabs" role="tablist">
                  {%- for tab_title in tab_titles -%}
                    {%- assign trimmed_title = tab_title | strip -%}
                    {%- if trimmed_title != blank -%}
                      <button
                        class="main-product__tab{% if forloop.first %} main-product__tab--active{% endif %}"
                        type="button"
                        role="tab"
                        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                        aria-controls="tab-panel-{{ section_id }}-{{ forloop.index0 }}"
                        id="tab-{{ section_id }}-{{ forloop.index0 }}"
                        data-tab-toggle
                      >
                        {{ trimmed_title }}
                      </button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <div class="main-product__tabs-content">
                  {%- for tab_title in tab_titles -%}
                    {%- assign trimmed_title = tab_title | strip -%}
                    {%- if trimmed_title != blank -%}
                      <div
                        class="main-product__tab-panel{% if forloop.first %} main-product__tab-panel--active{% endif %}"
                        id="tab-panel-{{ section_id }}-{{ forloop.index0 }}"
                        role="tabpanel"
                        aria-labelledby="tab-{{ section_id }}-{{ forloop.index0 }}"
                        data-tab-panel
                      >
                        {{ tab_contents[forloop.index0] | default: '' | newline_to_br }}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- when 'share_buttons' -%}
              {%- if show_share_buttons -%}
                <div class="main-product__share" {{ block.shopify_attributes }}>
                  <span class="main-product__share-label">{{ 'sections.main_product.share' | t }}</span>
                  <div class="main-product__share-buttons">
                    <a
                      href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}"
                      class="main-product__share-btn main-product__share-btn--facebook"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="{{ 'sections.main_product.share_on_facebook' | t }}"
                    >
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a
                      href="https://twitter.com/intent/tweet?text={{ product.title | url_encode }}&url={{ shop.url }}{{ product.url }}"
                      class="main-product__share-btn main-product__share-btn--twitter"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="{{ 'sections.main_product.share_on_twitter' | t }}"
                    >
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a
                      href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_media | image_url: width: 800 }}&description={{ product.title | url_encode }}"
                      class="main-product__share-btn main-product__share-btn--pinterest"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="{{ 'sections.main_product.share_on_pinterest' | t }}"
                    >
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.974-5.365 11.974-11.987C23.97 5.367 18.627.001 12.017.001z"/></svg>
                    </a>
                    <button
                      class="main-product__share-btn main-product__share-btn--copy"
                      type="button"
                      data-copy-link
                      aria-label="{{ 'sections.main_product.copy_link' | t }}"
                    >
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                    </button>
                  </div>
                </div>
              {%- endif -%}
            {%- when 'question_form' -%}
              <div class="main-product__question" {{ block.shopify_attributes }}>
                <button
                  class="main-product__question-toggle btn btn--text"
                  type="button"
                  data-modal-toggle="question-modal-{{ section_id }}"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                  </svg>
                  {{ 'sections.main_product.ask_question' | t }}
                </button>
                <div class="main-product__question-modal" id="question-modal-{{ section_id }}" role="dialog" aria-modal="true" aria-label="{{ 'sections.main_product.ask_question' | t }}" data-modal>
                  <div class="main-product__question-modal-overlay" data-modal-close></div>
                  <div class="main-product__question-modal-content">
                    <button class="main-product__question-modal-close" type="button" data-modal-close aria-label="{{ 'general.accessibility.close' | t }}">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M18 6L6 18M6 6l12 12"/>
                      </svg>
                    </button>
                    <h3 class="main-product__question-modal-title">{{ 'sections.main_product.ask_question' | t }}</h3>
                    {%- form 'contact', id: 'question-form-' | append: section_id, class: 'main-product__question-form' -%}
                      <input type="hidden" name="contact[product]" value="{{ product.title }}" />
                      <input type="hidden" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}" />
                      <div class="main-product__question-form-field">
                        <label for="question-name-{{ section_id }}">{{ 'sections.main_product.question_name' | t }}</label>
                        <input type="text" id="question-name-{{ section_id }}" name="contact[name]" required>
                      </div>
                      <div class="main-product__question-form-field">
                        <label for="question-email-{{ section_id }}">{{ 'sections.main_product.question_email' | t }}</label>
                        <input type="email" id="question-email-{{ section_id }}" name="contact[email]" required>
                      </div>
                      <div class="main-product__question-form-field">
                        <label for="question-message-{{ section_id }}">{{ 'sections.main_product.question_message' | t }}</label>
                        <textarea id="question-message-{{ section_id }}" name="contact[body]" rows="4" required></textarea>
                      </div>
                      <button type="submit" class="btn btn--primary main-product__question-form-submit">
                        {{ 'sections.main_product.question_submit' | t }}
                      </button>
                    {%- endform -%}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
{%- if product.media.size > 0 -%}
  {%- if product.media.first.media_type == 'model' -%}
    <script type="application/json" id="product-model-json-{{ section_id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
  {%- endif -%}
{%- endif -%}
<script type="application/json" id="product-json-{{ section_id }}">
  {{ product | json }}
</script>
