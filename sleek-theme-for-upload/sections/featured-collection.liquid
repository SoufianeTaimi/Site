{%- liquid
  assign collection = section.settings.collection
  assign enable_tabs = section.settings.enable_tabs
  assign desktop_columns = section.settings.desktop_columns
  assign mobile_columns = section.settings.mobile_columns
  assign limit = section.settings.limit | default: 8
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign tab_collections = section.settings.tab_collections
  assign tab_labels = section.settings.tab_labels
  assign tabs_raw = tab_labels | newline_to_br | strip_newlines | split: '<br />'
  assign tab_collections_raw = tab_collections | newline_to_br | strip_newlines | split: '<br />'
-%}
<section class="featured-collection" data-section-id="{{ section.id }}">
  <div class="featured-collection__container">
    {%- if heading != blank or subheading != blank -%}
      <div class="featured-collection__heading-wrapper">
        {%- if subheading != blank -%}
          <p class="featured-collection__subheading">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="featured-collection__heading">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if enable_tabs and collections != blank and tabs_raw.size > 0 -%}
      <div class="featured-collection__tabs" role="tablist">
        {%- for tab_label in tabs_raw -%}
          {%- assign trimmed_label = tab_label | strip -%}
          {%- if trimmed_label != blank -%}
            <button
              class="featured-collection__tab{% if forloop.first %} featured-collection__tab--active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-tab-index="{{ forloop.index0 }}"
            >
              {{ trimmed_label }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    <div
      class="featured-collection__grid"
      style="--desktop-columns: {{ desktop_columns }}; --mobile-columns: {{ mobile_columns }};"
      data-collection-grid
    >
      {%- liquid
        assign products_to_show = collection.products
        if enable_tabs
          assign products_to_show = collection.products
        endif
      -%}
      {%- if enable_tabs and tab_collections_raw.size > 0 -%}
        {%- for tab_collection_handle in tab_collections_raw -%}
          {%- assign trimmed_handle = tab_collection_handle | strip -%}
          {%- assign tab_collection = collections[trimmed_handle] -%}
          <div
            class="featured-collection__tab-content{% if forloop.first %} featured-collection__tab-content--active{% endif %}"
            data-tab-content="{{ forloop.index0 }}"
            role="tabpanel"
          >
            <div class="featured-collection__products">
              {%- if tab_collection != blank and tab_collection.products.size > 0 -%}
                {%- for product in tab_collection.products limit: limit -%}
                  {%- render 'product-card', product: product, section_id: section_id -%}
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..limit) -%}
                  {%- render 'product-card-placeholder' -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="featured-collection__tab-content featured-collection__tab-content--active" data-tab-content="0" role="tabpanel">
          <div class="featured-collection__products">
            {%- if collection != blank and collection.products.size > 0 -%}
              {%- for product in collection.products limit: limit -%}
                {%- render 'product-card', product: product, section_id: section_id -%}
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..limit) -%}
                {%- render 'product-card-placeholder' -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
    {%- if collection != blank and collection.url != blank -%}
      <div class="featured-collection__cta">
        <a href="{{ collection.url }}" class="btn btn--outline featured-collection__view-all">
          {{ 'sections.featured_collection.view_all' | t }}
          <span class="btn__arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "shopify-section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated for you"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the collection to feature."
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "checkbox",
      "id": "enable_tabs",
      "label": "Enable tab filtering",
      "info": "Show tab navigation to switch between collections.",
      "default": false
    },
    {
      "type": "textarea",
      "id": "tab_labels",
      "label": "Tab labels",
      "info": "One label per line. Example:\nFeatured\nBest Sellers\nSale",
      "default": "Featured\nBest Sellers\nSale"
    },
    {
      "type": "textarea",
      "id": "tab_collections",
      "label": "Tab collection handles",
      "info": "One collection handle per line, matching the order of tab labels. Example:\nfrontpage\nall\nsale",
      "default": "frontpage\nall\nsale"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "custom_product",
      "name": "Custom product",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "settings": {
        "heading": "Featured Collection",
        "subheading": "Curated for you",
        "collection": "",
        "limit": 8,
        "enable_tabs": true,
        "tab_labels": "Featured\nBest Sellers\nSale",
        "tab_collections": "frontpage\nall\nsale",
        "desktop_columns": "4",
        "mobile_columns": "2"
      }
    }
  ]
}
{% endschema %}
