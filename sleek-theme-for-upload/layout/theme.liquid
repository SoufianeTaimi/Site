<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_accent }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if settings.heading_font != blank -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="preload" as="font" href="{{ settings.heading_font | font_url }}" type="font/woff2" crossorigin>
  {%- endif -%}
  {%- if settings.body_font != blank -%}
    <link rel="preload" as="font" href="{{ settings.body_font | font_url }}" type="font/woff2" crossorigin>
  {%- endif -%}

  <style data-shopify>
    :root {
      --font-heading-family: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
      --font-heading-style: {{ settings.heading_font.style }};
      --font-heading-weight: {{ settings.heading_font.weight }};
      --font-heading-scale: {{ settings.heading_scale | times: 1.0 | divided_by: 100 }};

      --font-body-family: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
      --font-body-style: {{ settings.body_font.style }};
      --font-body-weight: {{ settings.body_font.weight }};
      --font-body-size: {{ settings.body_size }}px;

      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-heading: {{ settings.color_heading }};
      --color-accent: {{ settings.color_accent }};
      --color-accent-hover: {{ settings.color_accent_hover }};
      --color-button-bg: {{ settings.color_button_bg }};
      --color-button-text: {{ settings.color_button_text }};
      --color-border: {{ settings.color_border }};
      --color-light-bg: {{ settings.color_light_bg }};
      --color-header-bg: {{ settings.header_bg }};
      --color-header-text: {{ settings.header_text }};
      --color-footer-bg: {{ settings.footer_bg }};
      --color-footer-text: {{ settings.footer_text }};
      --color-footer-link: {{ settings.footer_link }};

      --button-border-radius: {{ settings.button_border_radius }}px;
      --page-width: {{ settings.page_width == 'narrow' ? '90' : settings.page_width == 'normal' ? '120' : '150' }}rem;

      --duration-short: 0.2s;
      --duration-medium: 0.4s;
      --duration-long: 0.6s;

      --z-index-dropdown: 100;
      --z-index-sticky: 200;
      --z-index-overlay: 300;
      --z-index-modal: 400;
      --z-index-popup: 500;
    }
  </style>

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    if (Shopify.designMode) document.documentElement.classList.add('shopify-design-mode');
  </script>

  <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}{% if settings.enable_sticky_header %} sticky-header{% endif %}">
  <a class="skip-to-content-link button" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {%- if settings.announcement_bar_enable -%}
    {% section 'announcement-bar' %}
  {%- endif -%}

  {% section 'header' %}

  {% section 'cart-drawer' %}

  <main id="MainContent" class="content-wrapper" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <ul hidden>
    <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
  </ul>

  <script>
    window.shopUrl = '{{ request.origin }}';
    window.routes = {
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      cart_url: '{{ routes.cart_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}'
    };
    window.cartStrings = {
      error: `{{ 'cart.error' | t }}`,
      quantityError: `{{ 'cart.quantity_error' | t }}`
    };
    window.variantStrings = {
      addToCart: `{{ 'products.product.add_to_cart' | t }}`,
      soldOut: `{{ 'products.product.sold_out' | t }}`,
      unavailable: `{{ 'products.product.unavailable' | t }}`,
      unavailable_with_option: `{{ 'products.product.value_unavailable' | t }}`
    };
    window.accessibilityStrings = {
      imageAvailable: `{{ 'products.product.media.image_available' | t: index: '1' }}`,
      shareSuccess: `{{ 'general.share.success_message' | t }}`,
      pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
      playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`
    };
  </script>

  {%- if settings.predictive_search_enabled -%}
    <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</body>
</html>
