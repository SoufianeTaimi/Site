{%- style -%}
  .testimonials-masonry {
    padding: 3rem 1.5rem;
    background: var(--color-secondary-background);
  }
  
  @media (min-width: 768px) {
    .testimonials-masonry {
      padding: 6rem 3rem;
    }
  }
  
  .testimonials__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .testimonials__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  .testimonial-card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid var(--color-primary, #c4301c);
  }
  
  .testimonial-card__content {
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-style: italic;
  }
  
  .testimonial-card__author {
    font-weight: 600;
    font-size: 0.95rem;
  }
  
  .testimonial-card__rating {
    color: #ffc107;
    margin-bottom: 0.5rem;
  }
{%- endstyle -%}

<div class="testimonials-masonry">
  <div class="testimonials__header">
    <h2 class="testimonials__heading">{{ section.settings.title }}</h2>
    {% if section.settings.description %}
      <p>{{ section.settings.description }}</p>
    {% endif %}
  </div>
  
  <div class="testimonials__grid">
    {% for block in section.blocks %}
      {% if block.type == 'testimonial' %}
        <div class="testimonial-card">
          {% if block.settings.rating %}
            <div class="testimonial-card__rating">
              {% for i in (1..block.settings.rating) %}★{% endfor %}
            </div>
          {% endif %}
          <div class="testimonial-card__content">
            "{{ block.settings.text }}"
          </div>
          <div class="testimonial-card__author">
            — {{ block.settings.author }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Customer Name"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Testimonial Text",
          "default": "<p>This is an amazing product!</p>"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
